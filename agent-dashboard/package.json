{
  "name": "agent-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:client": "vite --config client/vite.config.ts",
    "dev:server": "bun --watch server/index.ts",
    "dev": "concurrently --names client,server --prefix-colors auto \"bun run dev:client\" \"bun run dev:server\"",
    "build:client": "vite build --config client/vite.config.ts",
    "build": "bun run build:client",
    "typecheck:client": "tsc -p client/tsconfig.json --noEmit",
    "typecheck:server": "tsc -p server/tsconfig.json --noEmit",
    "typecheck": "bun run typecheck:client && bun run typecheck:server",
    "start": "bun run server/index.ts"
  },
  "dependencies": {
    "@ruh-ai/ruh-design-system": "^0.6.0",
    "@tanstack/react-query": "^5.100.10",
    "hono": "^4.6.14",
    "lucide-react": "^0.469.0",
    "next-themes": "^0.4.4",
    "postgres": "^3.4.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.0.0",
    "typescript": "latest",
    "vite": "^6.4.2"
  }
}
